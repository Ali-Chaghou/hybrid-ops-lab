# Kopieren nach make.env (gitignored) und Werte setzen.
# SSH-Erreichbarkeit der beiden Lab-VMs vom Desktop aus.
SSH_USER=ops
DC_HOST=
CLOUD_HOST=

# Host-Port, unter dem der Outbox-Publisher-/metrics-Endpunkt auf der site-dc-VM
# veroeffentlicht ist. Muss zu PUBLISHER_HOST_PORT in sites/dc/.env passen.
# Wird fuer das Prometheus-file_sd-Target (DC_HOST:PUBLISHER_HOST_PORT) genutzt.
PUBLISHER_HOST_PORT=8001
