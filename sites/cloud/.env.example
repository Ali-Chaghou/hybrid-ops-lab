# site-cloud — Vorlage. Die echte .env ist gitignored (.gitignore). KEINE echten
# Secrets committen. Pflicht-Passwoerter sind hier bewusst LEER: vor der Nutzung
# starke, zufaellige Werte erzeugen, z. B.:  openssl rand -base64 24
# Leere oder von ops.db.bootstrap abgelehnte Platzhalter (z. B. change-me) fuehren
# zu einem bewussten Fail-closed-Abbruch (DB/Bootstrap/Deploy starten nicht).

# --- SQS / Tooling ---
AWS_REGION=eu-central-1
SQS_ENDPOINT_URL=http://localhost:9324

# --- PostgreSQL Cluster-Admin (Superuser) — ausschliesslich Bootstrap/Prepare ---
POSTGRES_USER=hol_admin
POSTGRES_PASSWORD=
POSTGRES_DB=postgres

# --- Consumer-Idempotency-Store ---
CONSUMER_DB=consumer
# Host-Port-Mapping der Consumer-DB (Default 5433, um 5432-Kollisionen zu vermeiden).
# Der k3d-Consumer verbindet ueber host.k3d.internal:${CONSUMER_DB_HOST_PORT}.
CONSUMER_DB_HOST_PORT=5433

# --- Consumer-Rollen-Passwoerter (von ops.db.bootstrap gesetzt) ---
# consumer_admin: Migration + DB-Ownership. consumer_app: Runtime (Least-Privilege).
# Vor Nutzung mit starken Zufallswerten befuellen; leer = Fail closed.
CONSUMER_ADMIN_PASSWORD=
CONSUMER_APP_PASSWORD=
