# site-dc — NUR lokale Beispielwerte. Die echte .env ist gitignored (.gitignore).
# Keine echten Secrets committen. Die Rollen-Passwoerter duerfen keine von
# ops.db.bootstrap abgelehnten Platzhalter sein (z. B. change-me, change-me-local).

# --- PostgreSQL Cluster-Admin (Superuser) — ausschliesslich Bootstrap/Prepare ---
POSTGRES_USER=hol_admin
POSTGRES_PASSWORD=dc_admin_localpw
POSTGRES_DB=postgres

# --- Inventory-Datenbank ---
INVENTORY_DB=inventory

# --- Inventory-Rollen-Passwoerter (von ops.db.bootstrap gesetzt) ---
# inventory_admin: Migrationen + DB-Ownership. inventory_app: Runtime (Least-Privilege).
INVENTORY_ADMIN_PASSWORD=inv_admin_localpw
INVENTORY_APP_PASSWORD=inv_app_localpw

# --- Event-/SQS-Konfiguration (Phase 3; hier deaktiviert) ---
EVENTS_ENABLED=false
SQS_ENDPOINT_URL=
SQS_QUEUE_URL=
AWS_REGION=eu-central-1
