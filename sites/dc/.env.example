# site-dc — NUR lokale Beispielwerte. Die echte .env ist gitignored (.gitignore).
# Keine echten Secrets committen. Die Rollen-Passwoerter duerfen keine von
# ops.db.bootstrap abgelehnten Platzhalter sein (z. B. change-me, change-me-local).

# --- PostgreSQL Cluster-Admin (Superuser) — ausschliesslich Bootstrap/Prepare ---
POSTGRES_USER=hol_admin
POSTGRES_PASSWORD=dc_admin_localpw
POSTGRES_DB=postgres

# --- Inventory-Datenbank ---
INVENTORY_DB=inventory

# --- Inventory-Rollen-Passwoerter (von ops.db.bootstrap gesetzt) ---
# inventory_admin: Migrationen + DB-Ownership. inventory_app: Runtime (Least-Privilege).
INVENTORY_ADMIN_PASSWORD=inv_admin_localpw
INVENTORY_APP_PASSWORD=inv_app_localpw

# inventory_publisher: getrennte Least-Privilege-Rolle des Outbox-Publishers (Phase 3).
# Vor dem D3B-Deployment einen starken Zufallswert setzen (leer = Fail closed).
# Die Rolle wird vom Bootstrap angelegt; ihre Tabellenrechte erteilt Migration 0004.
# Dieses Passwort gelangt AUSSCHLIESSLICH an db-bootstrap und den publisher-Service.
INVENTORY_PUBLISHER_PASSWORD=

# --- Event-/SQS-Konfiguration der INVENTORY-Runtime (Phase 3; hier deaktiviert) ---
# Inventory publiziert NIE direkt; diese Werte bleiben leer/false.
EVENTS_ENABLED=false
SQS_ENDPOINT_URL=
SQS_QUEUE_URL=
AWS_REGION=eu-central-1

# --- Outbox-Publisher-Route (eigene Variablen, getrennt von der Inventory-Runtime) ---
# Erst in D3B mit echten Werten befuellen; leer/Platzhalter = der Publisher startet
# disabled und greift nicht auf die Queue zu. KEINE harte Adresse committen.
#   *_ENDPOINT_URL -> der bestehende Toxiproxy-Listener auf site-cloud (kein 2. Toxiproxy)
#   *_QUEUE_URL    -> die bestehende Main-Queue inventory-movements (keine 2. Queue)
# Endpoint- und Queue-URL weichen bewusst ab (Endpoint=Toxiproxy, Queue=ElasticMQ-Pfad).
# Tatsaechliche Erreichbarkeit (VM-Grenze) wird erst in D3B2 geprueft.
PUBLISHER_SQS_ENDPOINT_URL=
PUBLISHER_SQS_QUEUE_URL=
PUBLISHER_AWS_REGION=eu-central-1
# Host-Port, unter dem der Publisher-/metrics-Endpunkt auf der site-dc-VM erreichbar
# ist (Prometheus scrapt host:PUBLISHER_HOST_PORT ueber file_sd).
PUBLISHER_HOST_PORT=8001
